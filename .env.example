# Copy this file to .env.local and fill in the values

# NIP admin (pemilik akses penuh)
ADMIN_NIP=

# Session signing secret — generate a long random string
SESSION_SECRET=

# Supabase project credentials (get from https://supabase.com/dashboard/project/<project-id>/settings/api)
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=

# Vercel Blob read/write token (get from Vercel dashboard → Storage → your blob store → .env.local)
BLOB_READ_WRITE_TOKEN=
